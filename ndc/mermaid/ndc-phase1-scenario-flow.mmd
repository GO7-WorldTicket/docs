    direction LR
    NC1[OrderRetrieve] --> NC2[OrderReshop name change] --> NC3[OrderChange] --> NC4[OrderRetrieve]
  end
  subgraph cancel [Manage booking — cancel]
    direction LR
    CA1[OrderRetrieve] --> CA2[OrderReshop cancel] --> CA3[OrderChange] --> CA4[OrderRetrieve]
  end
  subgraph retrieve [Retrieve booking]
    direction LR
    RT1[OrderRetrieve]
  end
